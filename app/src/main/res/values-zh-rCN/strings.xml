    <string name="tutorial_subheading">SMS Forwarder 使用指南</string>
    <string name="section_about">应用说明</string>
    <string name="tutorial_about_body">当手机收到短信时，此应用会自动将短信数据以 HTTP 请求的方式发送到你指定的 Webhook URL。\n\n支持 POST、PUT、GET 三种方式，可自定义请求的 JSON 格式。格式中可使用变量占位符，发送时会自动替换为实际值。</string>
    <string name="section_variables">可用变量</string>
    <string name="var_receiver_desc">收件方号码 — 本机（这部手机）的电话号码，即接收短信的 SIM 卡号码。</string>
    <string name="var_sender_desc">发件人号码 — 发送此短信的人的电话号码。</string>
    <string name="var_message_desc">短信内容 — 这条短信的完整文字内容。</string>
    <string name="var_device_desc">设备名称 — 可在设置页面自定义，默认为手机型号（例如 Pixel 7）。适合多台手机同时使用时区分来源。</string>
    <string name="var_timestamp_desc">时间戳 — 应用收到短信的时间，格式为 ISO 8601 UTC（例如 2026-04-10T06:30:00Z）。</string>
    <string name="section_steps">配置步骤</string>
    <string name="step1_title">填写 Webhook URL</string>
    <string name="step1_desc">在「ENDPOINT」字段中输入你的 Webhook 地址。</string>
    <string name="step2_title">选择 HTTP 方法</string>
    <string name="step2_desc">POST / PUT：以 JSON Body 发送。GET：以 Query Parameter 发送。</string>
    <string name="step3_title">编辑请求体</string>
    <string name="step3_desc">在 Body 字段输入 JSON 模板，点击下方变量标签即可在光标处插入对应的占位符。</string>
    <string name="step4_title">点击「保存设置」</string>
    <string name="step4_desc">保存后，应用在后台收到短信时即会自动转发。</string>
    <string name="step5_title">授予必要权限</string>
    <string name="step5_desc">首次启动时会请求短信、联系人、电话等权限，请全部允许以确保功能正常。</string>
    <string name="section_testing">测试方式</string>
    <string name="test_send_title">发送测试</string>
    <string name="test_send_desc">使用固定的测试数据发送一次请求，验证 Webhook 是否可以正常接收。</string>
    <string name="test_inbox_title">从收件箱测试</string>
    <string name="test_inbox_desc">从手机收件箱选取真实短信，发送前显示 Payload 预览，确认变量替换正确后再发送。</string>
