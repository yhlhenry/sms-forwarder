<resources>
    <string name="app_name">SMS Forwarder</string>
    <string name="app_tagline">Forward incoming SMS to a Webhook</string>

    <!-- Home -->
    <string name="home_tutorial_title">Tutorial</string>
    <string name="home_tutorial_subtitle">Variables, setup steps &amp; testing guide</string>
    <string name="home_app_title">Open App</string>
