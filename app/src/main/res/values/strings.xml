    <!-- Tutorial page -->
    <string name="tutorial_heading">Setup Guide</string>
    <string name="tutorial_subheading">Connect SMS to your Slack channel</string>
    <string name="section_about">HOW IT WORKS</string>
    <string name="tutorial_about_body">This app listens for incoming SMS messages and automatically posts them to your Slack channel via an Incoming Webhook.\n\nNo server required. No account needed. Just paste a Slack webhook URL and you\'re done.</string>
    <string name="section_message_format">SLACK MESSAGE FORMAT</string>
    <string name="tutorial_message_format_body">📱 New SMS from +886912345678\n\nYour verification code is 1234.\n\nTo: +886987654321 · 2026-04-11T08:30:00Z · via Pixel 7</string>
    <string name="section_steps">SETUP STEPS</string>
    <string name="step1_title">Go to api.slack.com/apps</string>
    <string name="step1_desc">Open the Slack API site and sign in. Click "Create New App" → "From scratch".</string>
    <string name="step2_title">Name your app</string>
    <string name="step2_desc">Give it any name (e.g. "SMS Forwarder") and select your workspace. Click "Create App".</string>
    <string name="step3_title">Enable Incoming Webhooks</string>
    <string name="step3_desc">In the left sidebar click "Incoming Webhooks". Toggle the switch to ON.</string>
    <string name="step4_title">Add webhook to a channel</string>
    <string name="step4_desc">Scroll down and click "Add New Webhook to Workspace". Pick the channel where SMS should appear, then click "Allow".</string>
    <string name="step5_title">Copy the URL and paste it here</string>
    <string name="step5_desc">Copy the webhook URL (starts with https://hooks.slack.com/services/…) and paste it into the app. Save and you\'re done.</string>
    <string name="section_testing">TESTING</string>
    <string name="test_send_title">Send Test</string>
    <string name="test_send_desc">Sends a sample SMS to Slack to verify your webhook is working.</string>
    <string name="test_inbox_title">Test from Inbox</string>
    <string name="test_inbox_desc">Pick a real SMS from your inbox and preview exactly how it will look in Slack before going live.</string>
