    <string name="home_language_label">語言</string>
    <string name="tutorial_heading">教學說明</string>
    <string name="tutorial_subheading">SMS Forwarder 使用指南</string>
    <string name="section_about">APP 說明</string>
    <string name="tutorial_about_body">當手機收到 SMS 簡訊時，此 APP 會自動將簡訊資料以 HTTP 請求發送到你指定的 Webhook URL。\n\n支援 POST、PUT、GET 三種方式，並可自訂發送的 JSON 格式。格式中可使用變數佔位符，APP 發送時會自動替換成實際值。</string>
    <string name="section_variables">可用變數</string>
    <string name="var_receiver_desc">收件方號碼 — 這支手機（本機）的電話號碼，即收到簡訊的 SIM 卡號碼。</string>
    <string name="var_sender_desc">寄件者號碼 — 傳送這封簡訊的人的電話號碼（來電號碼）。</string>
    <string name="var_message_desc">簡訊內容 — 這封簡訊的完整文字內容。</string>
    <string name="var_device_desc">裝置名稱 — 可在設定頁自訂，預設為手機型號（例如 Pixel 7）。適合多台手機同時使用時區分來源。</string>
    <string name="var_timestamp_desc">時間戳記 — APP 收到簡訊的時間，格式為 ISO 8601 UTC（例如 2026-04-10T06:30:00Z）。</string>
    <string name="section_steps">設定步驟</string>
    <string name="step1_title">填入 Webhook URL</string>
    <string name="step1_desc">在「ENDPOINT」欄位輸入你的 Webhook 網址。</string>
    <string name="step2_title">選擇 HTTP 方法</string>
    <string name="step2_desc">POST / PUT：以 JSON Body 發送。GET：以 Query Parameter 發送。</string>
    <string name="step3_title">編輯 Request Body</string>
    <string name="step3_desc">在 Body 欄位輸入 JSON 範本，點擊下方變數 Chip 可直接在游標處插入對應佔位符。</string>
    <string name="step4_title">點擊「Save Settings」</string>
    <string name="step4_desc">儲存後，APP 在背景收到簡訊時即會自動轉發。</string>
    <string name="step5_title">授予必要權限</string>
    <string name="step5_desc">首次啟動時會要求簡訊、聯絡人、電話等權限，請全部允許以確保功能正常。</string>
    <string name="section_testing">測試方式</string>
    <string name="test_send_title">Send Test</string>
    <string name="test_send_desc">使用固定假資料發送一次請求，確認 Webhook 可正常接收。</string>
    <string name="test_inbox_title">從收件匣測試</string>
    <string name="test_inbox_desc">從手機收件匣選取真實簡訊，發送前顯示 Payload 預覽，確認變數正確替換後再送出。</string>
